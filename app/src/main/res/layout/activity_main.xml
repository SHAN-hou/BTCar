<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1A1A2E"
    android:padding="20dp"
    android:gravity="center_horizontal">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="蓝牙小车控制器"
        android:textColor="#E94560"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginTop="20dp" />

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="未连接"
        android:textColor="#AAAAAA"
        android:textSize="14sp"
        android:layout_marginTop="8dp" />

    <Button
        android:id="@+id/btnConnect"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="连接蓝牙"
        android:textSize="16sp"
        android:textColor="#FFFFFF"
        android:background="#0F3460"
        android:layout_marginTop="20dp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Forward -->
    <Button
        android:id="@+id/btnF"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:text="前进"
        android:textSize="20sp"
        android:textColor="#FFFFFF"
        android:background="#0F3460" />

    <View android:layout_width="match_parent" android:layout_height="16dp" />

    <!-- Left + Stop + Right -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnL"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:text="左转"
            android:textSize="20sp"
            android:textColor="#FFFFFF"
            android:background="#0F3460" />

        <View android:layout_width="16dp" android:layout_height="match_parent" />

        <Button
            android:id="@+id/btnS"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:text="停止"
            android:textSize="20sp"
            android:textColor="#FFFFFF"
            android:background="#E94560" />

        <View android:layout_width="16dp" android:layout_height="match_parent" />

        <Button
            android:id="@+id/btnR"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:text="右转"
            android:textSize="20sp"
            android:textColor="#FFFFFF"
            android:background="#0F3460" />
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="16dp" />

    <!-- Backward -->
    <Button
        android:id="@+id/btnB"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:text="后退"
        android:textSize="20sp"
        android:textColor="#FFFFFF"
        android:background="#0F3460" />

    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>
