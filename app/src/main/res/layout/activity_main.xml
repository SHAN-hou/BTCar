<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_gradient"
    android:padding="16dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp"
        android:background="@drawable/bg_card"
        android:layout_marginTop="20dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🚗 蓝牙小车"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />

        <View
            android:id="@+id/statusDot"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:layout_marginEnd="6dp"
            android:background="@drawable/status_dot" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="未连接"
            android:textColor="#CCCCCC"
            android:textSize="13sp" />
    </LinearLayout>

    <!-- Connect button -->
    <Button
        android:id="@+id/btnConnect"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="14dp"
        android:text="🔗 连接蓝牙"
        android:textSize="15sp"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:background="@drawable/btn_connect"
        android:stateListAnimator="@null" />

    <!-- Tab bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="14dp">

        <TextView
            android:id="@+id/tabControl"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="44dp"
            android:gravity="center"
            android:text="🎮 控制"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:background="@drawable/tab_selector"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/tabDebug"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="44dp"
            android:gravity="center"
            android:text="🛠 调试"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:background="@drawable/tab_selector" />
    </LinearLayout>

    <!-- Content area -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="14dp">

        <!-- ============ CONTROL PAGE ============ -->
        <LinearLayout
            android:id="@+id/pageControl"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/tvCurrentCmd"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="待 命"
                android:textColor="#00E5FF"
                android:textSize="22sp"
                android:textStyle="bold"
                android:letterSpacing="0.3"
                android:layout_marginBottom="20dp" />

            <!-- Forward -->
            <Button
                android:id="@+id/btnF"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:text="▲\n前进"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:lineSpacingExtra="-2dp"
                android:background="@drawable/btn_dir"
                android:stateListAnimator="@null" />

            <View
                android:layout_width="match_parent"
                android:layout_height="14dp" />

            <!-- L S R -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnL"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:text="◀\n左转"
                    android:textSize="16sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:lineSpacingExtra="-2dp"
                    android:background="@drawable/btn_dir"
                    android:stateListAnimator="@null" />

                <View android:layout_width="14dp" android:layout_height="match_parent" />

                <Button
                    android:id="@+id/btnS"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:text="■\n停止"
                    android:textSize="16sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:lineSpacingExtra="-2dp"
                    android:background="@drawable/btn_stop"
                    android:stateListAnimator="@null" />

                <View android:layout_width="14dp" android:layout_height="match_parent" />

                <Button
                    android:id="@+id/btnR"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:text="▶\n右转"
                    android:textSize="16sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:lineSpacingExtra="-2dp"
                    android:background="@drawable/btn_dir"
                    android:stateListAnimator="@null" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="14dp" />

            <!-- Backward -->
            <Button
                android:id="@+id/btnB"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:text="▼\n后退"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:lineSpacingExtra="-2dp"
                android:background="@drawable/btn_dir"
                android:stateListAnimator="@null" />
        </LinearLayout>

        <!-- ============ DEBUG PAGE ============ -->
        <LinearLayout
            android:id="@+id/pageDebug"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- Log area -->
            <ScrollView
                android:id="@+id/logScroll"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:padding="12dp"
                android:background="@drawable/bg_log">

                <TextView
                    android:id="@+id/tvLog"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="等待数据..."
                    android:textColor="#7FFFD4"
                    android:textSize="12sp"
                    android:fontFamily="monospace" />
            </ScrollView>

            <!-- Quick command buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="10dp">

                <Button
                    android:id="@+id/qF"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="40dp"
                    android:text="F"
                    android:textColor="#FFF"
                    android:textStyle="bold"
                    android:background="@drawable/btn_dir"
                    android:layout_marginEnd="4dp"
                    android:stateListAnimator="@null" />
                <Button
                    android:id="@+id/qB"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="40dp"
                    android:text="B"
                    android:textColor="#FFF"
                    android:textStyle="bold"
                    android:background="@drawable/btn_dir"
                    android:layout_marginEnd="4dp"
                    android:stateListAnimator="@null" />
                <Button
                    android:id="@+id/qL"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="40dp"
                    android:text="L"
                    android:textColor="#FFF"
                    android:textStyle="bold"
                    android:background="@drawable/btn_dir"
                    android:layout_marginEnd="4dp"
                    android:stateListAnimator="@null" />
                <Button
                    android:id="@+id/qR"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="40dp"
                    android:text="R"
                    android:textColor="#FFF"
                    android:textStyle="bold"
                    android:background="@drawable/btn_dir"
                    android:layout_marginEnd="4dp"
                    android:stateListAnimator="@null" />
                <Button
                    android:id="@+id/qS"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="40dp"
                    android:text="S"
                    android:textColor="#FFF"
                    android:textStyle="bold"
                    android:background="@drawable/btn_stop"
                    android:stateListAnimator="@null" />
            </LinearLayout>

            <!-- Input + send -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="10dp">

                <EditText
                    android:id="@+id/etCmd"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="48dp"
                    android:hint="输入命令"
                    android:textColorHint="#888"
                    android:textColor="#FFF"
                    android:textSize="14sp"
                    android:padding="12dp"
                    android:background="@drawable/bg_input"
                    android:singleLine="true" />

                <Button
                    android:id="@+id/btnSend"
                    android:layout_width="80dp"
                    android:layout_height="48dp"
                    android:text="发送"
                    android:textColor="#FFF"
                    android:textStyle="bold"
                    android:background="@drawable/btn_connect"
                    android:layout_marginStart="8dp"
                    android:stateListAnimator="@null" />
            </LinearLayout>

            <Button
                android:id="@+id/btnClearLog"
                android:layout_width="match_parent"
                android:layout_height="38dp"
                android:text="清空日志"
                android:textColor="#FFF"
                android:textSize="13sp"
                android:background="@drawable/btn_dir"
                android:layout_marginTop="10dp"
                android:stateListAnimator="@null" />
        </LinearLayout>
    </FrameLayout>
</LinearLayout>
