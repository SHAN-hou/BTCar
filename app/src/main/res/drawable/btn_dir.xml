<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:startColor="#5B4FCF"
                android:endColor="#3A2D8F" />
            <corners android:radius="28dp" />
            <stroke android:width="2dp" android:color="#7B6FFF" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:startColor="#3A2D8F"
                android:endColor="#1A1442" />
            <corners android:radius="28dp" />
            <stroke android:width="1dp" android:color="#5B4FCF" />
        </shape>
    </item>
</selector>
