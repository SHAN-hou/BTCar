<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="120"
                android:startColor="#FF6B9D"
                android:endColor="#C8336B" />
            <stroke android:width="2dp" android:color="#FFB3C7" />
        </shape>
    </item>
    <item>
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="120"
                android:startColor="#E94560"
                android:endColor="#8B1538" />
            <stroke android:width="2dp" android:color="#FF6B8A" />
        </shape>
    </item>
</selector>
